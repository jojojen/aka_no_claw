MONITOR_ENV=development
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/openclaw.log
LOG_RAW_RESULT_LIMIT=20
MONITOR_DB_PATH=data/monitor.sqlite3
YUYUTEI_USER_AGENT=OpenClawPriceMonitor/0.1 (+https://local-dev)
OPENCLAW_TELEGRAM_CHAT_ID=
OPENCLAW_TELEGRAM_BOT_TOKEN=
OPENCLAW_TESSERACT_PATH=auto
OPENCLAW_TESSDATA_DIR=auto
OPENCLAW_LOCAL_VISION_BACKEND=ollama
OPENCLAW_LOCAL_VISION_ENDPOINT=http://127.0.0.1:11434
# Mac mini M4 16GB preset:
# - gemma3:4b keeps enough memory for Telegram, reputation_snapshot, and Chromium.
# - For accuracy-first image checks, try gemma3:12b manually after confirming memory headroom.
# - qwen2.5vl:7b can be more capable for hard images, but requires Ollama 0.7.0+
#   and is better as an opt-in replacement, not a 16GB default.
OPENCLAW_LOCAL_VISION_MODEL=gemma3:4b
OPENCLAW_LOCAL_VISION_TIMEOUT_SECONDS=180
OPENCLAW_LOCAL_TEXT_BACKEND=ollama
OPENCLAW_LOCAL_TEXT_ENDPOINT=http://127.0.0.1:11434
# Mac mini M4 16GB text-routing preset:
# qwen3:4b is the balanced default for Chinese/Japanese command understanding.
# qwen3:8b is a good manual upgrade if you do not keep a larger vision model loaded.
# For a Pi 5 8GB, change this back to gemma3:1b before SETUP_OLLAMA=1.
OPENCLAW_LOCAL_TEXT_MODEL=qwen3:4b
OPENCLAW_LOCAL_TEXT_TIMEOUT_SECONDS=75
# /new codegen defaults to local Ollama. Set this to opencode to use OpenCode
# Big Pickle via `opencode run --pure` for generation/repair/validation while
# keeping OpenClaw's sandboxed generated-tool execution.
OPENCLAW_CODEGEN_BACKEND=
OPENCLAW_OPENCODE_BASE_URL=https://opencode.ai/zen/v1
OPENCLAW_OPENCODE_MODEL=big-pickle
OPENCLAW_OPENCODE_API_KEY=
OPENCLAW_OPENCODE_TIMEOUT_SECONDS=900
# Cloud big-pickle for the open-ended/abstract reasoning steps, while mechanical
# steps stay on local Ollama. Drives TWO features:
#   • /research appreciation summariser (price gate stays local), and
#   • /snsbuzz distiller — picking which specific card set / single card /
#     character / unit / product / event from raw 4chan chatter has appreciation
#     potential (local qwen3:14b is weak at this abstract step).
# Decoupled from OPENCLAW_CODEGEN_BACKEND above. On a cloud outage it degrades to
# a single in-process local call and never restarts the bot. Empty = local-only.
OPENCLAW_RESEARCH_CLOUD_ENRICHER=opencode
OPENCLAW_CA_BUNDLE_PATH=
OPENCLAW_TLS_INSECURE_SKIP_VERIFY=0
# ── Reputation Snapshot Agent ─────────────────────────────────────────────────
# Token must match ADMIN_TOKEN on the reputation-snapshot server.
# Leave REPUTATION_AGENT_ADMIN_TOKEN empty to disable the agent entirely.
REPUTATION_AGENT_SERVER_URL=http://127.0.0.1:5000
REPUTATION_AGENT_ADMIN_TOKEN=
REPUTATION_AGENT_POLL_SECS=5
# ── SNS / X (Twitter) Monitor ─────────────────────────────────────────────────
# Timeline monitoring uses Nitter RSS for X accounts (no login needed).
# /snsbuzz keyword search uses 4chan's public JSON API (no key needed) and
# records an IP-heat signal to ip_heat.sqlite3 (read by /research).
SNS_DB_PATH=data/sns.sqlite3
# ── Opportunity Agent ─────────────────────────────────────────────────────────
# Continuously links SNS buzz → fair-value pricing → Mercari listings → seller reputation
# and sends only qualified buying opportunities to Telegram.
OPENCLAW_OPPORTUNITY_AGENT_ENABLED=1
OPENCLAW_OPPORTUNITY_DB_PATH=data/opportunities.sqlite3
OPENCLAW_OPPORTUNITY_INTERVAL_SECONDS=900
OPENCLAW_OPPORTUNITY_LLM_TIMEOUT_SECONDS=180
OPENCLAW_OPPORTUNITY_SNS_LOOKBACK_HOURS=24
OPENCLAW_OPPORTUNITY_CANDIDATE_LIMIT=4
OPENCLAW_OPPORTUNITY_LISTING_LIMIT=5
OPENCLAW_OPPORTUNITY_CANDIDATE_CHECK_INTERVAL_SECONDS=1800
OPENCLAW_OPPORTUNITY_MIN_HEAT_SCORE=70
OPENCLAW_OPPORTUNITY_MAX_PRICE_RATIO=0.85
OPENCLAW_OPPORTUNITY_MIN_PRICE_CONFIDENCE=0.60
OPENCLAW_OPPORTUNITY_MIN_TOTAL_REVIEWS=30
OPENCLAW_OPPORTUNITY_MIN_POSITIVE_RATE=97
